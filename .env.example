# Database (PostgreSQL in produzione)
DATABASE_URL="postgresql://user:password@host:5432/familybudget"

# JWT — genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambia-questo-con-64-bytes-random-hex"
JWT_EXPIRES_IN="7d"

# Server
NODE_ENV="production"
PORT=3000

# CORS — URL del frontend in produzione
CORS_ORIGIN="https://tuodominio.com"

# Plaid (Open Banking)
PLAID_CLIENT_ID=""
PLAID_SECRET=""
PLAID_ENV="production"          # sandbox | development | production
PLAID_REDIRECT_URI="https://tuodominio.com"
PLAID_PRODUCTS="transactions"
PLAID_COUNTRY_CODES="IT"

# Anthropic (categorizzazione AI fallback)
ANTHROPIC_API_KEY=""
CLAUDE_CATEGORIZER_ENABLED=true

# Google Places (arricchimento merchant, opzionale)
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACES_ENABLED=false
GOOGLE_PLACES_CACHE_DAYS=365

# Upload
MAX_FILE_SIZE="10485760"
UPLOAD_PATH="./uploads"

# Sicurezza
BCRYPT_ROUNDS="12"
