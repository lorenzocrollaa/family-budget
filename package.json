{
  "name": "family-budget-api",
  "version": "1.0.0",
  "description": "API per Family Budget Tracker con parsing automatico estratti conto",
  "main": "app.js",
  "scripts": {
    "start": "node app.js",
    "dev": "nodemon app.js",
    "db:migrate": "npx prisma migrate dev",
    "db:migrate:deploy": "npx prisma migrate deploy",
    "db:generate": "npx prisma generate",
    "db:seed": "node prisma/seed.js",
    "db:studio": "npx prisma studio",
    "test": "jest",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@prisma/client": "^6.18.0",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^1.1.1",
    "plaid": "^41.4.0",
    "stripe": "^22.0.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "prettier": "^3.1.1",
    "prisma": "^6.18.0",
    "supertest": "^6.3.3"
  },
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=8.0.0"
  },
  "keywords": [
    "family-budget",
    "expense-tracker",
    "bank-statement-parser",
    "transaction-categorization",
    "financial-api",
    "pdf-parser",
    "csv-parser",
    "prisma",
    "express",
    "jwt-auth"
  ],
  "author": "Family Budget Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/family-budget-api"
  },
  "bugs": {
    "url": "https://github.com/your-org/family-budget-api/issues"
  },
  "homepage": "https://github.com/your-org/family-budget-api#readme"
}
